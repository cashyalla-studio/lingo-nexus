# Copy to .env and fill in values
PORT=8080

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=lingo_nexus
MYSQL_USER=lingo
MYSQL_PASSWORD=lingopassword
DATABASE_URL=lingo:lingopassword@tcp(localhost:3306)/lingo_nexus?parseTime=true&charset=utf8mb4&loc=UTC

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-secret-in-production

# LLM API Keys
QWEN_API_KEY=your-qwen-api-key
GEMINI_API_KEY=your-gemini-api-key

# Google OAuth (for verifying client tokens)
# No server-side credential needed — we verify using Google's tokeninfo endpoint
